WC_BASE_URL=https://tooliano.com
WC_CONSUMER_KEY=ck_your_key_here
WC_CONSUMER_SECRET=cs_your_secret_here

# رفع صور المنتج إلى WordPress Media (Application Password — ليس كلمة دخول wp-admin)
# WP_URL=https://tooliano.com
# WP_USERNAME=
# WP_APP_PASSWORD=
# أسماء بديلة مدعومة:
# WP_MEDIA_USER=admin
# WP_MEDIA_USERNAME=admin

NEXT_PUBLIC_SITE_NAME=Tooliano
# يُفضّل مطابقة النطاق الحقيقي (Vercel أو tooliano.com) لـ PWA
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=EGP
NEXT_PUBLIC_CURRENCY_LOCALE=ar-EG

# إنتاج (Hostinger): MySQL — فعّل Remote MySQL في hPanel لـ Vercel
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME?connection_limit=5"

# بديل: Neon Postgres
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# مصدر ترحيل SQLite المحلي (npm run migrate:sqlite-to-db)
# SQLITE_PATH=./prisma/dev.db

JWT_SECRET=generate-a-long-random-string-min-16-chars

# حساب المدير الافتراضي (بعد npm run db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# مدة حملة الشراء الجماعي بعد موافقة الأدmin (أيام) — الافتراضي 7 في الكود
# DEFAULT_CAMPAIGN_DAYS=7

# روابط المتجر الأصلي (حساب عميل، سلة، قائمة أمنيات على WordPress)
NEXT_PUBLIC_WP_STORE_ORIGIN=https://tooliano.com

# روابط السوشيال (ضع روابط صفحاتك الحقيقية)
# تُستورد تلقائياً عند seed أول مرة — بعدها من لوحة Admin → محتوى → السوشيال
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# رابط صفحة المفضلة على WordPress (إن وُجدت إضافة مثل YITH)
# NEXT_PUBLIC_WP_WISHLIST_URL=https://tooliano.com/wishlist/

# حملة الشراء الجماعي (لاندنج)
NEXT_PUBLIC_CAMPAIGN_PRODUCT_ID=4846
NEXT_PUBLIC_CAMPAIGN_RETAIL_PRICE=1000
NEXT_PUBLIC_CAMPAIGN_GROUP_PRICE=750
NEXT_PUBLIC_CAMPAIGN_TARGET_QTY=200
NEXT_PUBLIC_CAMPAIGN_RESERVED_QTY=45
# NEXT_PUBLIC_CAMPAIGN_ENDS_AT=2026-12-31T23:59:59.000Z

# محفظة العميل والتسليم
DEPOSIT_PERCENT=5
DELIVERY_CODE_TTL_DAYS=7
DELIVERY_CODE_MAX_ATTEMPTS=10
# DELIVERY_CODE_PEPPER=

# Paymob (Fawry عبر Paymob)
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_HMAC_SECRET=
# PAYMOB_IFRAME_ID=
# PAYMOB_ALLOW_DEV_SIMULATE=true

# مندوب تجريبي (بعد db:seed)
# DELIVERY_AGENT_USERNAME=agent1
# DELIVERY_AGENT_PASSWORD=agent123
