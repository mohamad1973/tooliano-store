{
  "name": "tooliano-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "npx tsx scripts/vercel-build.ts",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:setup": "dotenv -e .env.local -- prisma db push && dotenv -e .env.local -- prisma generate",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "locate:dev-db": "npx tsx scripts/locate-dev-db.ts",
    "migrate:sqlite-to-db": "dotenv -e .env.local -- npx tsx scripts/migrate-sqlite-to-neon.ts",
    "migrate:sqlite-to-neon": "npm run migrate:sqlite-to-db",
    "migrate:vendor-images": "dotenv -e .env.local -- npx tsx scripts/migrate-vendor-images-to-wp.ts",
    "verify:db": "dotenv -e .env.local -- npx tsx scripts/verify-db.ts",
    "verify:neon-db": "npm run verify:db",
    "extend:campaigns": "dotenv -e .env.local -- npx tsx scripts/extend-expired-campaigns.ts",
    "env:sync-db-url": "npx tsx scripts/sync-database-url.ts",
    "setup:hostinger": "npx tsx scripts/setup-hostinger-db.ts",
    "test:mysql": "dotenv -e .env.local -- npx tsx scripts/test-mysql-connection.ts",
    "setup:wp-env": "npx tsx scripts/ensure-wp-env.ts",
    "check:wp-media": "npx tsx scripts/check-wp-media.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.10.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
